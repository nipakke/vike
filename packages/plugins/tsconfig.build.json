{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "es2023",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "noEmit": true,
    "types": [
      "node"
    ],
    "composite": true
  },
  "include": [
    "src"
  ]
}