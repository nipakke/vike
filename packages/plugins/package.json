{
  "name": "@nipakke/vike-vue-plugins",
  "private": true,
  "description": "Vue plugins",
  "version": "0.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nipakke/vike.git",
    "directory": "packages/plugins"
  },
  "bugs": {
    "url": "https://github.com/nipakke/vike/issues"
  },
  "homepage": "https://github.com/nipakke/vike/tree/main/packages/plugins#readme",
  "keywords": [
    "vike",
    "vue-plugins",
    "vue",
    "ssr",
    "vite"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./vike": {
      "import": {
        "types": "./dist/vike.d.ts",
        "default": "./dist/vike.js"
      },
      "require": {
        "types": "./dist/vike.d.cts",
        "default": "./dist/vike.cjs"
      }
    },
    "./vue": {
      "import": {
        "types": "./dist/vue.d.ts",
        "default": "./dist/vue.js"
      },
      "require": {
        "types": "./dist/vue.d.cts",
        "default": "./dist/vue.cjs"
      }
    }
  },
  "scripts": {
    "dev": "vp pack --watch",
    "build": "vp pack",
    "test:e2e": "playwright test",
    "test:browser": "vitest --config=vitest.browser.config.ts"
  },
  "dependencies": {
    "@playwright/test": "^1.59.1",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/browser-preview": "^4.1.5",
    "@vue/server-renderer": "^3.5.33",
    "devalue": "^5.7.1",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.0",
    "unctx": "^2.5.0",
    "vite": "catalog:",
    "vitest": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@unhead/vue": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitest/coverage-v8": "^4.1.5",
    "playwright": "^1.59.1",
    "unhead": "catalog:",
    "vike": "catalog:",
    "vike-vue": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vue": "catalog:"
  },
  "peerDependencies": {
    "vike": ">=0.4.249",
    "vike-vue": ">=0.7.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  }
}